      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="stall-trace" name="4 Stall Trace Counters">
    <mxGraphModel dx="1500" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="850" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="Stall, Trace, and Performance Counter Control" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=20;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1420" height="50" as="geometry"/></mxCell>
        <mxCell id="fsm" value="Miss / base latency state&lt;br&gt;miss_active&lt;br&gt;miss_wait_count&lt;br&gt;base_active&lt;br&gt;base_wait_count&lt;br&gt;fill_pulse" style="shape=process;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="210" height="140" as="geometry"/></mxCell>
        <mxCell id="stallcache" value="CACHE_ENABLE path&lt;br&gt;stall = miss_active | start_miss" style="shape=logic;operation=or;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="405" y="150" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="stallbase" value="cache disabled path&lt;br&gt;stall = base_active | delayed base access" style="shape=logic;operation=or;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="405" y="290" width="180" height="90" as="geometry"/></mxCell>
