<mxfile host="app.diagrams.net" modified="2026-05-28T17:05:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="overview" name="1 Control Overview">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="Readable Cache Control Overview - Direct-Mapped L1/L2 D-Cache" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=20;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1520" height="50" as="geometry"/></mxCell>
        <mxCell id="note" value="This page avoids long crossing wires. Named net stubs show the same physical RTL signals; pages 2-4 expand each control cluster with gates." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=center;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="1520" height="40" as="geometry"/></mxCell>

        <mxCell id="req" value="MEM-stage request pins&lt;br&gt;&lt;b&gt;cache_req&lt;/b&gt; = req_valid &amp;amp; (req_load | req_store)&lt;br&gt;addr[31:0], wdata[31:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="70" y="190" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="l1" value="L1 hit/miss logic&lt;br&gt;index = addr[2 +: L1_INDEX_BITS]&lt;br&gt;req_tag = addr[31 -: L1_TAG_BITS]&lt;br&gt;&lt;b&gt;line_hit&lt;/b&gt; = CACHE_ENABLE &amp;amp; valid[index] &amp;amp; (tag[index] == req_tag)&lt;br&gt;&lt;b&gt;start_hit/start_miss&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="430" y="160" width="340" height="170" as="geometry"/></mxCell>
        <mxCell id="l2" value="L2 hit/miss logic&lt;br&gt;l2_index = addr[2 +: L2_INDEX_BITS]&lt;br&gt;l2_req_tag = addr[31 -: L2_TAG_BITS]&lt;br&gt;&lt;b&gt;l2_line_hit&lt;/b&gt; = L2_ENABLE &amp;amp; l2_valid[l2_index] &amp;amp; (l2_tag[l2_index] == l2_req_tag)&lt;br&gt;l2_hit_pulse / l2_miss_pulse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="860" y="160" width="350" height="170" as="geometry"/></mxCell>
        <mxCell id="mem" value="Backing memory and fills&lt;br&gt;word_addr = {2'b00, addr[31:2]}&lt;br&gt;mem[word_addr]&lt;br&gt;write-through store update&lt;br&gt;fill L2, then fill L1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1300" y="170" width="230" height="150" as="geometry"/></mxCell>

        <mxCell id="rdata" value="Read data mux&lt;br&gt;CACHE hit: data[index]&lt;br&gt;L2 hit: l2_data[l2_index]&lt;br&gt;miss/base: mem[word_addr]&lt;br&gt;&lt;b&gt;rdata[31:0]&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="540" y="480" width="280" height="135" as="geometry"/></mxCell>
        <mxCell id="stall" value="Stall generation&lt;br&gt;CACHE_ENABLE: stall = miss_active | start_miss&lt;br&gt;cache disabled: stall = base_active | delayed base access&lt;br&gt;&lt;b&gt;stall -&gt; dcache_stall -&gt; mem_stall -&gt; pipeline_stall&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="920" y="470" width="360" height="150" as="geometry"/></mxCell>
        <mxCell id="trace" value="Trace/counter outputs&lt;br&gt;trace_access/start_access&lt;br&gt;trace_hit/start_hit&lt;br&gt;trace_miss/start_miss&lt;br&gt;trace_fill/fill_pulse&lt;br&gt;trace_l2_access/hit/miss&lt;br&gt;perf L1/L2/backing counters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1300" y="460" width="230" height="180" as="geometry"/></mxCell>

        <mxCell id="e1" value="cache_req, addr, wdata" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="req" target="l1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="on L1 miss: l2 access" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="on L2 miss / store write-through" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l2" target="mem"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="l1/l2/mem data" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l1" target="rdata"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="miss/wait control" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l2" target="stall"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="event pulses" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="stall" target="trace"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="fill data" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="mem" target="l2"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="l1-detail" name="2 L1 Gates">
    <mxGraphModel dx="1500" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="850" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="L1 Control Gates - Request Decode, Tag Compare, Hit/Miss" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=20;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1420" height="50" as="geometry"/></mxCell>
        <mxCell id="inputs" value="Inputs from core / local state&lt;br&gt;req_valid&lt;br&gt;req_load&lt;br&gt;req_store&lt;br&gt;addr[31:0]&lt;br&gt;miss_active&lt;br&gt;base_active&lt;br&gt;replay_suppress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="185" height="185" as="geometry"/></mxCell>
        <mxCell id="orls" value="OR&lt;br&gt;req_load | req_store" style="shape=logic;operation=or;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="320" y="175" width="110" height="70" as="geometry"/></mxCell>
        <mxCell id="cache_req" value="AND&lt;br&gt;cache_req =&lt;br&gt;req_valid &amp;amp; (req_load | req_store)" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="500" y="170" width="140" height="85" as="geometry"/></mxCell>
        <mxCell id="start_access" value="AND&lt;br&gt;start_access =&lt;br&gt;cache_req &amp;amp; !miss_active&lt;br&gt;&amp;amp; !base_active &amp;amp; !replay_suppress" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="720" y="160" width="170" height="105" as="geometry"/></mxCell>

        <mxCell id="addrsplit" value="Address split&lt;br&gt;index = addr[2 +: L1_INDEX_BITS]&lt;br&gt;req_tag = addr[31 -: L1_TAG_BITS]&lt;br&gt;word_addr = {2'b00, addr[31:2]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="70" y="430" width="250" height="110" as="geometry"/></mxCell>
        <mxCell id="arrays" value="L1 arrays&lt;br&gt;valid[index]&lt;br&gt;tag[index]&lt;br&gt;data[index]" style="shape=component;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="420" y="410" width="160" height="125" as="geometry"/></mxCell>
        <mxCell id="cmp" value="==&lt;br&gt;tag[index] == req_tag" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="675" y="425" width="120" height="90" as="geometry"/></mxCell>
        <mxCell id="line_hit" value="AND&lt;br&gt;line_hit =&lt;br&gt;CACHE_ENABLE &amp;amp; valid[index]&lt;br&gt;&amp;amp; tag_match" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="900" y="415" width="165" height="105" as="geometry"/></mxCell>
        <mxCell id="start_hit" value="AND&lt;br&gt;start_hit =&lt;br&gt;start_access &amp;amp; CACHE_ENABLE &amp;amp; line_hit" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1160" y="320" width="170" height="95" as="geometry"/></mxCell>
        <mxCell id="start_miss" value="AND&lt;br&gt;start_miss =&lt;br&gt;start_access &amp;amp; CACHE_ENABLE &amp;amp; !line_hit" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1160" y="515" width="170" height="95" as="geometry"/></mxCell>
        <mxCell id="outputs" value="Outputs to other pages&lt;br&gt;start_hit -&gt; L1 data return/counter&lt;br&gt;start_miss -&gt; L2 lookup / miss FSM&lt;br&gt;line_hit -&gt; trace_hit and data mux select" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1120" y="675" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="e1" value="req_load/store" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="inputs" target="orls"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="req_valid + load/store" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="orls" target="cache_req"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="cache_req + not busy" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="cache_req" target="start_access"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="index" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="addrsplit" target="arrays"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="tag[index], req_tag" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="arrays" target="cmp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="tag_match + valid[index]" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="cmp" target="line_hit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="line_hit" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="line_hit" target="start_hit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="!line_hit" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="line_hit" target="start_miss"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="start_access" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="start_access" target="start_hit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="start_access" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="start_access" target="start_miss"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="start_hit" target="outputs"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="start_miss" target="outputs"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="l2-memory" name="3 L2 and Memory Gates">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="L2 / Backing Memory Control - Miss Handling, Fill, Store Policy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=20;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1420" height="50" as="geometry"/></mxCell>
        <mxCell id="miss_capture" value="On start_miss, capture&lt;br&gt;miss_addr, miss_wdata&lt;br&gt;miss_load, miss_store&lt;br&gt;miss_index/tag&lt;br&gt;miss_l2_index/tag&lt;br&gt;miss_word_addr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="230" height="145" as="geometry"/></mxCell>
        <mxCell id="l2_arrays" value="L2 arrays&lt;br&gt;l2_valid[l2_index]&lt;br&gt;l2_tag[l2_index]&lt;br&gt;l2_data[l2_index]" style="shape=component;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="410" y="145" width="180" height="130" as="geometry"/></mxCell>
        <mxCell id="cmp" value="==&lt;br&gt;l2_tag[l2_index] == l2_req_tag" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="705" y="160" width="135" height="100" as="geometry"/></mxCell>
        <mxCell id="l2hit" value="AND&lt;br&gt;l2_line_hit =&lt;br&gt;L2_ENABLE &amp;amp; l2_valid[l2_index]&lt;br&gt;&amp;amp; l2_tag_match" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="950" y="150" width="180" height="110" as="geometry"/></mxCell>
        <mxCell id="l2_result" value="Decision&lt;br&gt;l2_hit_pulse if l2_line_hit&lt;br&gt;l2_miss_pulse if !l2_line_hit&lt;br&gt;miss_uses_l2 tracks source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1230" y="150" width="210" height="115" as="geometry"/></mxCell>

        <mxCell id="backing" value="Backing memory&lt;br&gt;mem[miss_word_addr]&lt;br&gt;read on L2 miss/load&lt;br&gt;write on store write-through" style="shape=component;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="420" y="440" width="210" height="125" as="geometry"/></mxCell>
        <mxCell id="storegate" value="AND&lt;br&gt;store_write =&lt;br&gt;miss_store &amp;amp; write_through" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="120" y="465" width="155" height="85" as="geometry"/></mxCell>
        <mxCell id="fill_l2" value="AND&lt;br&gt;l2_fill_en =&lt;br&gt;backing_resp_valid &amp;amp; L2_ENABLE" style="shape=logic;operation=and;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="750" y="420" width="165" height="90" as="geometry"/></mxCell>
        <mxCell id="fill_l1" value="OR&lt;br&gt;l1_fill_en =&lt;br&gt;l2_hit_resp | backing_resp_valid&lt;br&gt;| store_write_allocate" style="shape=logic;operation=or;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1015" y="425" width="180" height="105" as="geometry"/></mxCell>
        <mxCell id="l1arrays" value="L1 fill/update&lt;br&gt;valid[miss_index] &lt;= 1&lt;br&gt;tag[miss_index] &lt;= miss_tag&lt;br&gt;data[miss_index] &lt;= fill_data" style="shape=component;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1260" y="420" width="200" height="120" as="geometry"/></mxCell>

        <mxCell id="rdata" value="rdata select&lt;br&gt;L1 hit: data[index]&lt;br&gt;L2 hit/miss: fill/mem data&lt;br&gt;cache disabled: mem[word_addr]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="640" y="680" width="255" height="110" as="geometry"/></mxCell>
        <mxCell id="policy" value="Store policy used by this experiment&lt;br&gt;write-through&lt;br&gt;write-allocate-style cache update&lt;br&gt;stores update backing memory and cache line when applicable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1010" y="665" width="360" height="110" as="geometry"/></mxCell>

        <mxCell id="e1" value="miss_l2_index/tag" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="miss_capture" target="l2_arrays"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="tag compare" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l2_arrays" target="cmp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="tag_match + valid" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="cmp" target="l2hit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="l2_hit/l2_miss" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l2hit" target="l2_result"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="store write-through" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="storegate" target="backing"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="L2 miss read" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="l2_result" target="backing"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="backing_resp_valid" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="backing" target="fill_l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="l2_fill_en" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="fill_l2" target="l2_arrays"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="fill source" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="fill_l2" target="fill_l1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="l1_fill_en" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="fill_l1" target="l1arrays"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="read data" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="backing" target="rdata"><mxGeometry relative="1" as="geometry"/></mxCell>
